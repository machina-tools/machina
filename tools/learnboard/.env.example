# LearnBoard configuration
# Copy this file to .env and adjust values

# Port to listen on (default: 4331)
LEARNBOARD_PORT=4331

# Path to your learning markdown file (default: ./LEARNING.md in current dir)
LEARNING_FILE=./LEARNING.md

# Directory for automatic backups (default: .learnboard-backups/ next to LEARNING_FILE)
LEARNBOARD_BACKUP_DIR=./.learnboard-backups

# Section markers — customize if your learning file uses different headers
SECTION_REQUESTS=### User Requests
SECTION_SUGGESTIONS=### Suggestions Log
SECTION_LESSONS=### Lessons Learned
SECTION_OBSERVATIONS=### AI Observations
