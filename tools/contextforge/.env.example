# ContextForge configuration
# Copy this file to .env and adjust values

# Port to listen on (default: 4328)
CONTEXTFORGE_PORT=4328

# Path to servers.json (shared with BugCapture)
SERVERS_CONFIG=~/.config/machina/servers.json

# Directory where BugCapture saves its .md reports
BUGCAPTURE_OUTPUT_DIR=~/bugcapture-output
