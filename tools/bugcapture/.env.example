# BugCapture configuration
# Copy this file to .env and adjust values

# Port to listen on (default: 4327)
BUGCAPTURE_PORT=4327

# Path to servers.json (shared with ContextForge)
SERVERS_CONFIG=~/.config/machina/servers.json

# Whisper transcription language (default: english)
# Other values: italian, french, spanish, german, etc.
WHISPER_LANGUAGE=english

# Directory for Whisper model cache (default: ~/.cache/huggingface/hub)
WHISPER_CACHE=~/.cache/huggingface/hub
