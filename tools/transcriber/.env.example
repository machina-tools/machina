# Transcriber — local Whisper transcription service
# Used by: PromptBoard (Firefox/Brave voice), BugCapture Web, LearnBoard Web

TRANSCRIBER_PORT=4324

# Whisper language for transcription (default: english)
# Examples: italian, french, spanish, german, portuguese
TRANSCRIBER_LANGUAGE=english

# Whisper model to use (default: whisper-base, ~150 MB)
# Larger = more accurate, slower first load
# Options: Xenova/whisper-tiny | Xenova/whisper-base | Xenova/whisper-small
TRANSCRIBER_MODEL=Xenova/whisper-base
