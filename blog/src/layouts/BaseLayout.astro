---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description = 'Machina — open-source AI tools that close the gap between seeing a bug and fixing it.', ogImage } = Astro.props;
const base = import.meta.env.BASE_URL;
const BREVO_ACTION = "https://5d3be9d9.sibforms.com/serve/MUIFAIn7IRpmiqnzJd2S_ckaeJU-t0nAn8FNfAFgvVW9hS1KpSrA9DaE02ZAQ5AIZnzWHb6C2sNme7xqNWzEjIOdNsgN6EXhqoM-VVDLEt5sD7rNJ945jIjBQhNt8SuZvjv5Fvbv3t5-dJQcOi6CoDCbSOIkH5jDhALn2idBp4phZZKiX5W_hd68H0v3pF2VCIAf15-BO87YU23kXw==";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:site_name" content="Machina">
  <meta property="og:type" content="website">
  {ogImage && <meta property="og:image" content={ogImage}>}
  <meta name="twitter:card" content="summary_large_image">
  {ogImage && <meta name="twitter:image" content={ogImage}>}
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png">
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg:       #07080e;
      --bg2:      #0c0d16;
      --surface:  #111220;
      --surface2: #181930;
      --border:   #1f2040;
      --text:     #f0f4ff;
      --muted:    #6677aa;
      --teal:     #00c8e0;
      --teal-dim: #009bb0;
      --teal-glow:rgba(0,200,224,.15);
      --purple:   #7c3aed;
      --font:     'Inter', system-ui, sans-serif;
      --mono:     'JetBrains Mono', monospace;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    a { color: var(--teal); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── NAV ── */
    nav {
      border-bottom: 1px solid var(--border);
      padding: 0 40px;
      height: 60px;
      display: flex;
      align-items: center;
      gap: 24px;
      position: sticky;
      top: 0;
      background: rgba(7,8,14,.92);
      backdrop-filter: blur(12px);
      z-index: 100;
    }
    nav::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, var(--teal), var(--purple));
      opacity: 0.2;
    }
    .nav-logo img { height: 42px; width: auto; display: block; }
    .nav-divider { color: var(--border); font-size: 18px; font-weight: 300; user-select: none; }
    .nav-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: .02em;
    }
    .nav-right { margin-left: auto; display: flex; gap: 20px; align-items: center; }
    .nav-link {
      font-size: 13px;
      font-weight: 500;
      color: var(--muted);
      transition: color .15s, text-shadow .15s;
    }
    .nav-link:hover { color: #e07820; text-shadow: 0 0 4px #e07820, 0 0 12px #c96010, 0 0 28px #b04c00cc, 0 0 52px #b04c0066; text-decoration: none; }
    .nav-cta {
      padding: 6px 16px;
      background: linear-gradient(135deg, var(--teal), #0090e0);
      color: #07080e;
      border-radius: 6px;
      font-weight: 700;
      font-size: 12px;
    }
    .nav-cta:hover { opacity: .85; text-decoration: none; }

    main { flex: 1; }

    /* ── FOOTER ── */
    .footer-main {
      background: var(--bg2);
      border-top: 1px solid var(--border);
    }
    .footer-nl {
      padding: 56px 40px;
      max-width: 640px;
      margin: 0 auto;
      text-align: center;
      border-bottom: 1px solid var(--border);
    }
    .footer-nl .label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.2px;
      color: var(--teal);
      margin-bottom: 10px;
    }
    .footer-nl h3 {
      font-size: 22px;
      font-weight: 800;
      letter-spacing: -.4px;
      margin-bottom: 10px;
    }
    .footer-nl p {
      font-size: 14px;
      color: var(--muted);
      margin-bottom: 24px;
      line-height: 1.6;
    }
    .nl-form {
      display: flex;
      gap: 8px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .nl-form input[type="email"] {
      padding: 10px 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 7px;
      color: var(--text);
      font-size: 14px;
      outline: none;
      width: 260px;
      transition: border-color .15s;
      font-family: var(--font);
    }
    .nl-form input[type="email"]:focus { border-color: var(--teal); }
    .nl-form input[type="email"]::placeholder { color: #3a4a6a; }
    .nl-btn {
      padding: 10px 20px;
      background: linear-gradient(135deg, var(--teal), #0090e0);
      color: #07080e;
      border: none;
      border-radius: 7px;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
      font-family: var(--font);
    }
    .nl-note { margin-top: 10px; font-size: 11px; color: #3a4a6a; }
    .footer-bottom {
      padding: 24px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }
    .footer-logo img { height: 26px; width: auto; }
    .footer-links { display: flex; gap: 20px; }
    .footer-links a { font-size: 12px; color: var(--muted); }
    .footer-links a:hover { color: #e07820; text-shadow: 0 0 4px #e07820, 0 0 12px #c96010, 0 0 28px #b04c00cc; text-decoration: none; }
    .footer-copy { font-size: 12px; color: #2a3a5a; }

    @media (max-width: 640px) {
      nav { padding: 0 20px; gap: 14px; }
      .footer-nl { padding: 40px 20px; }
      .footer-bottom { padding: 20px; }
    }
  </style>
  <script defer src="https://cloud.umami.is/script.js" data-website-id="05f90f24-c05e-44cc-a3db-c4612520ab21"></script>
</head>
<body>
  <nav>
    <a href="https://machina.chat" class="nav-logo">
      <img src="/assets/logo-horizontal.png" alt="Machina">
    </a>
    <span class="nav-divider">|</span>
    <span class="nav-label">Blog</span>
    <div class="nav-right">
      <a href={`${base}/`} class="nav-link">All posts</a>
      <a href="https://github.com/machina-tools/machina" class="nav-link" target="_blank">GitHub</a>
      <a href="https://machina.chat" class="nav-cta">machina.chat →</a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer-main">
    <div class="footer-nl">
      <div class="label">Stay in the loop</div>
      <h3>New tools, lessons, and AI workflow insights</h3>
      <p>Monthly digest of what was built, what was learned, and what's next. No spam.</p>
      <form class="nl-form" method="POST" action={BREVO_ACTION}>
        <input type="email" name="EMAIL" placeholder="your@email.com" required>
        <button type="submit" class="nl-btn">Subscribe →</button>
        <input type="text" name="email_address_check" value="" style="display:none">
        <input type="hidden" name="locale" value="it">
        <input type="hidden" name="html_type" value="simple">
      </form>
      <p class="nl-note">No spam · Unsubscribe anytime</p>
    </div>
    <script>
      document.querySelectorAll('.nl-form').forEach(form => {
        if (form.dataset.nlAttached) return;
        form.dataset.nlAttached = '1';
        form.addEventListener('submit', async e => {
          e.preventDefault();
          const btn = form.querySelector('button[type="submit"]');
          btn.disabled = true; btn.textContent = 'Subscribing…';
          try { await fetch(form.action, { method: 'POST', body: new FormData(form), mode: 'no-cors' }); } catch (_) {}
          const container = form.closest('.footer-nl') || form.closest('.nl-card') || form.closest('.newsletter-wrap') || form.parentElement;
          const note = container && container.querySelector('.nl-note');
          const msg = document.createElement('p');
          msg.style.cssText = 'margin-top:16px;font-size:15px;color:#4ade80;font-weight:600;text-align:center;';
          msg.textContent = '✓ Almost there — check your inbox to confirm your subscription.';
          form.replaceWith(msg);
          if (note) note.style.display = 'none';
        });
      });
    </script>
    <div class="footer-bottom">
      <a href="https://machina.chat">
        <img src="/assets/logo-horizontal.png" alt="Machina" class="footer-logo" style="height:22px">
      </a>
      <div class="footer-links">
        <a href={`${base}/`}>Blog</a>
        <a href="https://machina.chat/#tools">Tools</a>
        <a href="https://github.com/machina-tools/machina" target="_blank">GitHub</a>
        <a href="mailto:contact@machina.chat">Contact</a>
      </div>
      <span class="footer-copy">© {new Date().getFullYear()} Machina · MIT License</span>
    </div>
  </footer>
</body>
</html>
