---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL;
const BREVO_ACTION = "https://5d3be9d9.sibforms.com/serve/MUIFAIn7IRpmiqnzJd2S_ckaeJU-t0nAn8FNfAFgvVW9hS1KpSrA9DaE02ZAQ5AIZnzWHb6C2sNme7xqNWzEjIOdNsgN6EXhqoM-VVDLEt5sD7rNJ945jIjBQhNt8SuZvjv5Fvbv3t5-dJQcOi6CoDCbSOIkH5jDhALn2idBp4phZZKiX5W_hd68H0v3pF2VCIAf15-BO87YU23kXw==";

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<BaseLayout
  title={`${frontmatter.title} — Machina Blog`}
  description={frontmatter.description}
  ogImage={frontmatter.ogImage}
>
  <article class="post">

    <!-- HEADER -->
    <div class="post-header">
      <a href={`${base}/`} class="back-link">← All posts</a>
      <div class="post-meta-top">
        {frontmatter.tag && <span class="tag">{frontmatter.tag}</span>}
        <time>{formatDate(frontmatter.date)}</time>
        {frontmatter.readingTime && <span class="read-time">{frontmatter.readingTime} min read</span>}
      </div>
      <h1>{frontmatter.title}</h1>
      <p class="post-description">{frontmatter.description}</p>

      {(frontmatter.github || frontmatter.youtube) && (
        <div class="post-links">
          {frontmatter.github && (
            <a href={frontmatter.github} target="_blank" class="post-link post-link-github">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              View on GitHub
            </a>
          )}
          {frontmatter.youtube && (
            <a href={`https://www.youtube.com/watch?v=${frontmatter.youtube}`} target="_blank" class="post-link post-link-youtube">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              Watch demo
            </a>
          )}
        </div>
      )}
    </div>

    <!-- YOUTUBE EMBED -->
    {frontmatter.youtube && (
      <div class="video-wrap">
        <div class="video-container">
          <iframe
            src={`https://www.youtube.com/embed/${frontmatter.youtube}`}
            title={`${frontmatter.title} — demo`}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            style="position:absolute;top:0;left:0;width:100%;height:100%;">
          </iframe>
        </div>
        <p class="video-caption">Watch the demo — see it in action before reading.</p>
      </div>
    )}

    <!-- BODY -->
    <div class="prose">
      <slot />
    </div>

    <!-- FOOTER LINKS -->
    {(frontmatter.github || frontmatter.youtube) && (
      <div class="post-footer-links">
        <div class="pfl-label">Try it yourself</div>
        <div class="pfl-items">
          {frontmatter.github && (
            <a href={frontmatter.github} target="_blank" class="pfl-btn pfl-github">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              View source on GitHub
            </a>
          )}
          {frontmatter.youtube && (
            <a href={`https://www.youtube.com/watch?v=${frontmatter.youtube}`} target="_blank" class="pfl-btn pfl-yt">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              Watch on YouTube
            </a>
          )}
          <a href="https://machina.chat" class="pfl-btn pfl-site">machina.chat →</a>
        </div>
      </div>
    )}

    <!-- NEWSLETTER INLINE -->
    <div class="post-newsletter">
      <div class="pnl-label">Stay in the loop</div>
      <h3>New tools, workflows, and AI dev insights</h3>
      <p>Monthly digest of what was built, what was learned, and what's next.</p>
      <form class="nl-form" method="POST" action={BREVO_ACTION}>
        <input type="email" name="EMAIL" placeholder="your@email.com" required>
        <button type="submit" class="nl-btn">Subscribe →</button>
        <input type="text" name="email_address_check" value="" style="display:none">
        <input type="hidden" name="locale" value="it">
        <input type="hidden" name="html_type" value="simple">
      </form>
      <p class="nl-note">No spam · Unsubscribe anytime</p>
    </div>

  </article>
</BaseLayout>

<style>
  .post {
    max-width: 740px;
    margin: 0 auto;
    padding: 56px 24px 96px;
  }

  /* ── HEADER ── */
  .post-header {
    margin-bottom: 48px;
    padding-bottom: 36px;
    border-bottom: 1px solid var(--border);
  }
  .back-link {
    display: inline-block;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 24px;
    transition: color .15s;
  }
  .back-link:hover { color: var(--teal); text-decoration: none; }
  .post-meta-top { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
  .tag {
    font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    padding: 3px 10px; border-radius: 99px;
    background: rgba(0,200,224,.08); border: 1px solid rgba(0,200,224,.2); color: var(--teal);
  }
  time, .read-time { font-size: 12px; color: var(--muted); }
  h1 {
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    line-height: 1.18;
    letter-spacing: -.6px;
    color: var(--text);
    margin-bottom: 16px;
  }
  .post-description {
    font-size: 17px;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 24px;
  }
  .post-links { display: flex; gap: 10px; flex-wrap: wrap; }
  .post-link {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 7px 14px; border-radius: 8px;
    font-size: 13px; font-weight: 600;
    border: 1px solid var(--border);
    transition: border-color .15s, color .15s;
  }
  .post-link:hover { text-decoration: none; }
  .post-link-github { color: var(--text); }
  .post-link-github:hover { border-color: var(--text); }
  .post-link-youtube { color: #ff4444; }
  .post-link-youtube:hover { border-color: #ff4444; }

  /* ── VIDEO ── */
  .video-wrap { margin-bottom: 56px; }
  .video-container {
    position: relative; padding-bottom: 56.25%; height: 0;
    border-radius: 12px; overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 0 60px rgba(0,200,224,.12);
  }
  .video-caption { font-size: 13px; color: var(--muted); text-align: center; margin-top: 12px; font-style: italic; }

  /* ── PROSE ── */
  .prose { font-size: 17px; line-height: 1.82; color: #c8d4f0; }

  .prose :global(h2) {
    font-size: 1.5rem; font-weight: 700; color: var(--text);
    margin-top: 56px; margin-bottom: 18px; letter-spacing: -.03em;
    padding-top: 0;
  }
  .prose :global(h3) {
    font-size: 1.15rem; font-weight: 700; color: var(--text);
    margin-top: 36px; margin-bottom: 14px;
  }
  .prose :global(p) { margin-bottom: 22px; }
  .prose :global(a) {
    color: var(--teal);
    text-decoration: underline;
    text-decoration-color: rgba(0,200,224,.3);
  }
  .prose :global(a:hover) { text-decoration-color: var(--teal); }
  .prose :global(strong) { color: var(--text); font-weight: 600; }
  .prose :global(em) { color: #a0b0d0; }

  .prose :global(code) {
    font-family: var(--mono); font-size: .85em;
    background: rgba(255,255,255,.06); border: 1px solid var(--border);
    border-radius: 4px; padding: 2px 6px; color: #7ee8f8;
  }
  .prose :global(pre) {
    background: #090c14 !important; border: 1px solid var(--border);
    border-radius: 10px; padding: 22px; overflow-x: auto;
    margin: 28px 0; font-size: .875rem; line-height: 1.65;
  }
  .prose :global(pre code) { background: none; border: none; padding: 0; color: inherit; font-size: inherit; }

  .prose :global(blockquote) {
    border-left: 3px solid var(--teal); margin: 28px 0;
    padding: 6px 0 6px 22px; color: var(--muted); font-style: italic;
    background: rgba(0,200,224,.04); border-radius: 0 6px 6px 0;
  }
  .prose :global(ul), .prose :global(ol) { margin: 18px 0 22px 28px; display: flex; flex-direction: column; gap: 10px; }
  .prose :global(li) { color: #c8d4f0; }
  .prose :global(hr) { border: none; border-top: 1px solid var(--border); margin: 48px 0; }
  .prose :global(img) { max-width: 100%; border-radius: 10px; border: 1px solid var(--border); margin: 28px 0; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 28px 0; font-size: .9rem; }
  .prose :global(th) { background: var(--surface); border: 1px solid var(--border); padding: 10px 14px; color: var(--text); font-weight: 600; text-align: left; }
  .prose :global(td) { border: 1px solid var(--border); padding: 9px 14px; color: #c8d4f0; }
  .prose :global(tr:nth-child(even) td) { background: rgba(255,255,255,.02); }

  /* ── FOOTER LINKS ── */
  .post-footer-links {
    margin-top: 64px;
    padding: 32px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
  }
  .pfl-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin-bottom: 16px; }
  .pfl-items { display: flex; gap: 10px; flex-wrap: wrap; }
  .pfl-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 18px; border-radius: 8px;
    font-size: 14px; font-weight: 600;
    transition: opacity .15s;
  }
  .pfl-btn:hover { opacity: .85; text-decoration: none; }
  .pfl-github { background: var(--bg2); border: 1px solid var(--border); color: var(--text); }
  .pfl-yt { background: #1a0a0a; border: 1px solid #3a1a1a; color: #ff6666; }
  .pfl-site { background: linear-gradient(135deg, var(--teal), #0090e0); color: #07080e; }

  /* ── NEWSLETTER ── */
  .post-newsletter {
    margin-top: 48px;
    padding: 40px 36px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .post-newsletter::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(0,200,224,.06) 0%, transparent 60%);
    pointer-events: none;
  }
  .pnl-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px; color: var(--teal); margin-bottom: 10px; }
  .post-newsletter h3 { font-size: 20px; font-weight: 700; letter-spacing: -.3px; margin-bottom: 8px; }
  .post-newsletter p { font-size: 14px; color: var(--muted); margin-bottom: 20px; }
  .nl-form { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
  .nl-form input[type="email"] {
    padding: 10px 16px; background: var(--bg2); border: 1px solid var(--border);
    border-radius: 7px; color: var(--text); font-size: 14px; outline: none;
    width: 240px; transition: border-color .15s; font-family: var(--font);
  }
  .nl-form input[type="email"]:focus { border-color: var(--teal); }
  .nl-form input[type="email"]::placeholder { color: #2a3a5a; }
  .nl-btn {
    padding: 10px 20px; background: linear-gradient(135deg, var(--teal), #0090e0);
    color: #07080e; border: none; border-radius: 7px;
    font-weight: 700; font-size: 14px; cursor: pointer; font-family: var(--font);
  }
  .nl-note { margin-top: 10px; font-size: 11px; color: #2a3a5a; }

  @media (max-width: 640px) {
    .post { padding: 36px 20px 72px; }
    h1 { font-size: 24px; }
    .post-newsletter { padding: 28px 20px; }
    .post-footer-links { padding: 24px 20px; }
    .pfl-items { flex-direction: column; }
    .pfl-btn { justify-content: center; }
  }
</style>
